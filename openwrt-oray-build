name: Build OpenOray IPK

on:
  workflow_dispatch:
    inputs:
      package:
        description: '选择要编译的包'
        required: true
        default: 'luci-app-phtunnel'
        type: choice
        options:
          - luci-app-pgyvpn
          - luci-app-phtunnel
          - pgyvpn
          - phtunnel

jobs:
  build:
    runs-on: ubuntu-22.04

    steps:
    - name: 安装依赖
      run: |
        sudo apt-get update
        sudo apt-get install -y \
          build-essential clang flex bison g++ gawk \
          gcc-multilib g++-multilib gettext git \
          libncurses-dev libssl-dev python3-distutils \
          rsync unzip zlib1g-dev file wget

    - name: 克隆 OpenWrt 源码
      run: |
        git clone --depth=1 https://github.com/openwrt/openwrt.git
        cd openwrt
        ./scripts/feeds update -a
        ./scripts/feeds install -a

    - name: 克隆 OpenOray 包
      run: |
        cd openwrt
        mkdir -p package/openwrt-packages
        cd package/openwrt-packages
        git clone https://github.com/OrayOS/OpenOray

    - name: 配置编译
      run: |
        cd openwrt
        cat > .config << 'EOF'
        CONFIG_TARGET_x86=y
        CONFIG_TARGET_x86_64=y
        EOF
        echo "CONFIG_PACKAGE_${{ github.event.inputs.package }}=m" >> .config
        make defconfig

    - name: 下载依赖
      run: |
        cd openwrt
        make download -j8

    - name: 编译包
      run: |
        cd openwrt
        make package/openwrt-packages/OpenOray/${{ github.event.inputs.package }}/compile V=s -j$(nproc)

    - name: 列出编译产物
      run: |
        find openwrt/bin/packages -name "*.ipk"

    - name: 上传 IPK
      uses: actions/upload-artifact@v4
      with:
        name: ${{ github.event.inputs.package }}-ipk
        path: openwrt/bin/packages/**/*.ipk
        if-no-files-found: warn
